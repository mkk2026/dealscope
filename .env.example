# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real keys.

# ── Fireworks AI (AMD-hardware models) ──
# Both pipeline stages run on AMD GPUs via Fireworks. The routing is the product:
# a cheap model for bulk extraction, a premium one for the single synthesis call.
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=

# Models your Fireworks account can access (GET /v1/models to list).
# Extraction = high-volume + cheap; synthesis = premium + one call.
EXTRACT_MODEL=accounts/fireworks/models/gpt-oss-120b
SYNTH_MODEL=accounts/fireworks/models/deepseek-v4-pro

# ── Optional ──
# A GitHub token lifts the public API rate limit from 60/hr to 5000/hr.
# Create one at github.com/settings/tokens with read-only public access.
GITHUB_TOKEN=
