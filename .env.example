# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real keys.

# ── Stage 1: bulk extraction on a self-hosted open model (AMD Instinct GPU pod) ──
# Once you run vLLM or Ollama on the AMD pod, it exposes an OpenAI-compatible
# endpoint. Put that URL here (e.g. http://<pod-ip>:8000/v1 for vLLM).
# NOTE: the AMD Developer Cloud platform token (dop_...) is for managing pods,
# not necessarily for inference. Self-hosted vLLM usually needs no auth key.
AMD_BASE_URL=http://localhost:8000/v1
AMD_API_KEY=not-needed
# Qwen2.5-7B is non-gated (no HF token). Llama-3.1-8B works too but needs a license.
AMD_MODEL=Qwen/Qwen2.5-7B-Instruct
# Pod-side metrics server (pod/metrics_server.py) for the live cost-race + GPU gauge.
# Leave blank until the pod is up; then set to http://<pod-ip>:9100/
AMD_METRICS_URL=

# ── Stages 2-3: Fireworks AI (AMD-hardware models) ──
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=
# Pick a chat model your Fireworks account can access (GET /v1/models to list).
# These are reasoning models — the code uses JSON mode to keep output clean.
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro

# ── Optional ──
# A GitHub token lifts the public API rate limit from 60/hr to 5000/hr.
# Create one at github.com/settings/tokens with read-only public access.
GITHUB_TOKEN=
